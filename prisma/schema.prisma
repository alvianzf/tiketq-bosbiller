// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

enum ServiceType {
  FLIGHT
  FERRY
  CAR_RENTAL
}

model Transaction {
  id              Int         @id @default(autoincrement())
  serviceType     ServiceType
  bookingCode     String?     @unique
  email           String?
  basePrice       Decimal?    @default(0)
  serviceFee      Decimal?    @default(0)
  totalSales      Decimal?    @default(0)
  payment_status  Boolean     @default(false)
  status          String?     @default("PENDING")
  
  flightBooking   FlightBooking? @relation(fields: [flightBookingId], references: [id])
  flightBookingId Int?           @unique
  ferryBooking    FerryBooking?  @relation(fields: [ferryBookingId], references: [id])
  ferryBookingId  Int?           @unique
  carRentalRequest CarRentalRequest? @relation(fields: [carRentalRequestId], references: [id])
  carRentalRequestId Int?          @unique

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@map("transactions")
}

model FlightBooking {
  id             Int      @id @default(autoincrement())
  bookingCode    String?  @unique
  nominal        String?
  basePrice      Decimal? @default(0)
  serviceFee     Decimal? @default(0)
  totalSales     Decimal? @default(0)
  departureDate  String?
  origin         String?
  destination    String?
  email          String?
  mobile_number  String?
  name           String?
  book_date      DateTime @default(now())
  payment_status Boolean  @default(false)
  transaction    Transaction?
  passengers     Passenger[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("flight_bookings")
}

model FerryBooking {
  id             Int      @id @default(autoincrement())
  bookingNo      String?  @unique
  nominal        String?
  basePrice      Decimal? @default(0)
  serviceFee     Decimal? @default(0)
  totalSales     Decimal? @default(0)
  departureDate  DateTime?
  returnDate     DateTime?
  originId       Int?
  destinationId  Int?
  origin         Terminal? @relation("OriginTerminal", fields: [originId], references: [id])
  destination    Terminal? @relation("DestinationTerminal", fields: [destinationId], references: [id])
  email          String?
  mobile_number  String?
  status         String?   @default("PENDING")
  payment_status Boolean  @default(false)
  transaction    Transaction?
  passengers     Passenger[]
  book_date      DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("ferry_bookings")
}

model Passenger {
  id              Int      @id @default(autoincrement())
  title           String?
  firstName       String
  lastName        String
  passportNumber  String?
  nationality     String?
  dateOfBirth     DateTime?
  flightBookingId Int?
  ferryBookingId  Int?
  flightBooking   FlightBooking? @relation(fields: [flightBookingId], references: [id])
  ferryBooking    FerryBooking?  @relation(fields: [ferryBookingId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("passengers")
}

model Terminal {
  id                  Int      @id @default(autoincrement())
  code                String   @unique
  name                String
  city                String?
  country             String?
  originFerryBookings      FerryBooking[] @relation("OriginTerminal")
  destinationFerryBookings FerryBooking[] @relation("DestinationTerminal")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("terminals")
}

model Car {
  id              Int        @id @default(autoincrement())
  name            String
  type            String
  rows            Int
  pricePerDay     Decimal
  pricingDuration String?    @default("hari")
  transmission    String?
  description     String?
  features        String[]
  available       Boolean    @default(true)
  photos       CarPhoto[]
  rentals      CarRentalRequest[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("cars")
}

model CarPhoto {
  id        Int      @id @default(autoincrement())
  filename  String
  url       String
  isPrimary Boolean  @default(false)
  car       Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  carId     Int
  createdAt DateTime @default(now())

  @@map("car_photos")
}

model CarRentalRequest {
  id         Int      @id @default(autoincrement())
  car        Car      @relation(fields: [carId], references: [id])
  carId      Int
  date       String
  rentalDays Int?     @default(1)
  fullName   String
  phone      String
  email      String
  ktpImage   String
  ktpSelfie  String
  status     String   @default("PENDING_REVIEW")
  transaction Transaction?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("car_rental_requests")
}
